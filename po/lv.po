#: Settings.ui.h:128
msgid "Always on top"
msgstr "Vienmēr virspusē"

#: Settings.ui.h:129
msgid "Animation duration (s)"
msgstr "Animācijas ilgums (s)"

#: Settings.ui.h:130
msgid "Show timeout (s)"
msgstr "Rādīšanas aizture (s)"

#: Settings.ui.h:131
msgid "Pressure threshold"
msgstr "Spiediena slieksnis"
