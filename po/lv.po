msgstr "Pielāgot doka krāsu"

#: Settings.ui.h:95
msgid "Tune the dash background opacity."
msgstr "Pielāgot doka fona caurspīdīgumu."

#: Settings.ui.h:97
msgid "Fixed"
msgstr "Fiksēts"

#: Settings.ui.h:98
msgid "Dynamic"
