#: Settings.ui.h:1
msgid ""
"When set to minimize, double clicking minimizes all the windows of the "
"application."
msgstr ""
"Quando definido como minimizar, um clique duplo minimiza todas as janelas "
"do aplicativo."

#: Settings.ui.h:2
msgid "Shift+Click action"
msgstr "Ação do Shift+Clique"

#: Settings.ui.h:3
msgid "Raise window"
msgstr "Trazer janela para frente"

#: Settings.ui.h:4
msgid "Minimize window"
msgstr "Minimizar janela"

#: Settings.ui.h:5
msgid "Launch new instance"
msgstr "Iniciar nova instância"

#: Settings.ui.h:6
msgid "Cycle through windows"
msgstr "Alternar entre janelas"

#: Settings.ui.h:7
msgid "Minimize or overview"
msgstr "Minimizar ou visão geral"

#: Settings.ui.h:8
msgid "Show window previews"
msgstr "Mostrar pré-visualizações das janelas"

#: Settings.ui.h:9
msgid "Minimize or show previews"
msgstr "Minimizar ou mostrar pré-visualizações"

#: Settings.ui.h:10
msgid "Focus or show previews"
msgstr "Pôr em foco ou mostrar pré-visualizações"

#: Settings.ui.h:11
msgid "Focus or app spread"
msgstr "Focar ou usar app spread"

#: Settings.ui.h:12
msgid "Focus, minimize or show previews"
msgstr "Pôr em foco, minimizar ou mostrar pré-visualizações"

#: Settings.ui.h:13
msgid "Focus, minimize or app spread"
msgstr "Focar, minimizar ou usar app spread"

#: Settings.ui.h:14
msgid "Quit"
msgstr "Sair"

#: Settings.ui.h:13
msgid "Behavior for Middle-Click."
msgstr "Comportamento do clique do botão do meio."

#: Settings.ui.h:14
msgid "Middle-Click action"
msgstr "Ação do Clique do botão do meio"

#: Settings.ui.h:15
msgid "Behavior for Shift+Middle-Click."
msgstr "Comportamento para Shift+clique do botão do meio."

#: Settings.ui.h:16
msgid "Shift+Middle-Click action"
msgstr "Ação do Shift+Clique do botão do meio"

#: Settings.ui.h:17
msgid "Enable Unity7 like glossy backlit items"
msgstr "Ativar itens com retroiluminação brilhante no estilo do Unity 7"

#: Settings.ui.h:18
msgid "Apply glossy effect."
msgstr "Aplicar efeito brilhante."

#: Settings.ui.h:19
msgid "Use dominant color"
msgstr "Usar cor dominante"

#: Settings.ui.h:20
msgid "Customize indicator style"
msgstr "Personalizar o estilo do indicador"

#: Settings.ui.h:21
msgid "Color"
msgstr "Cor"

#: Settings.ui.h:22
msgid "Border color"
msgstr "Cor da borda"

#: Settings.ui.h:23
msgid "Border width"
msgstr "Tamanho da borda"

#: Settings.ui.h:24
msgid "Show the dock on"
msgstr "Mostrar o dock em"

#: Settings.ui.h:25
msgid "Show on all monitors"
msgstr "Mostrar em todos os monitores"

#: Settings.ui.h:26
msgid "Position on screen"
msgstr "Posição na tela"

#: Settings.ui.h:28
msgid "Bottom"
msgstr "Embaixo"

#: Settings.ui.h:29
msgid "Top"
msgstr "Em cima"

#: Settings.ui.h:31
msgid ""
"Hide the dock when it obstructs a window of the current application. More "
"refined settings are available."
msgstr ""
"Ocultar o dock quando ele obstruir uma janela do aplicativo atual. "
"Configurações mais detalhadas estão disponíveis."

#: Settings.ui.h:32
msgid "Intelligent autohide"
msgstr "Ocultação inteligente"

#: Settings.ui.h:33
msgid "Dock size limit"
msgstr "Limite do tamanho do dock"

#: Settings.ui.h:34
msgid "Panel mode: extend to the screen edge"
msgstr "Modo do painel: estender até a borda da tela"

#: Settings.ui.h:35
msgid "Icon size limit"
msgstr "Limite do tamanho dos ícones"

#: Settings.ui.h:36
msgid "Fixed icon size: scroll to reveal other icons"
msgstr "Tamanho fixo dos ícones: role para revelar outros ícones"

#: Settings.ui.h:37
msgid "Place icons to the center"
msgstr "Centralizar ícones"

#: Settings.ui.h:38
msgid "Preview size scale"
msgstr "Escala do tamanho da pré-visualização"

#: Settings.ui.h:39
msgid "Position and size"
msgstr "Posição e tamanho"

#: Settings.ui.h:39
msgid "Show pinned applications"
msgstr "Mostrar aplicativos fixados"

#: Settings.ui.h:40
msgid "Show running applications"
msgstr "Mostrar aplicativos em execução"

#: Settings.ui.h:41
msgid "Isolate workspaces"
msgstr "Isolar espaços de trabalho"

#: Settings.ui.h:42
msgid "Show urgent windows despite current workspace"
msgstr "Mostrar janelas urgentes apesar do espaço de trabalho atual"

#: Settings.ui.h:43
msgid "Isolate monitors"
msgstr "Isolar monitores"

#: Settings.ui.h:44
msgid "Show open windows previews"
msgstr "Mostrar pré-visualizações de janelas abertas"

#: Settings.ui.h:45
msgid "Show open windows' previews"
msgstr "Mostrar pré-visualizações de janelas abertas"

#: Settings.ui.h:46
msgid "Keep the focused application always visible in the dash"
msgstr "Manter o aplicativo em foco sempre visível no dock"

#: Settings.ui.h:46
msgid ""
"If disabled, these settings are accessible from gnome-tweak-tool or the "
"extension website."
msgstr ""
"Se desativado, essas configurações ficam acessíveis pelo gnome-tweak-tool "
"ou pelo site da extensão."

#: Settings.ui.h:47
msgid "Show <i>Applications</i> icon"
msgstr "Exibir ícone dos <i>Aplicativos</i>"

#: Settings.ui.h:48
msgid "Move the applications button at the beginning of the dock"
msgstr "Mover o botão de aplicativos para o início do dock"

#: Settings.ui.h:49
msgid "Move at beginning of the dock"
msgstr "Mover para o início do dock"

#: Settings.ui.h:50
msgid "Animate <i>Show Applications</i>"
msgstr "Animar <i>Mostrar aplicativos</i>"

#: Settings.ui.h:51
msgid "Put <i>Show Applications</i> in a dock edge when using Panel mode"
msgstr "Colocar <i>Mostrar aplicativos</i> em uma extremidade do dock ao usar o modo painel"

#: Settings.ui.h:52
msgid "Show trash can"
msgstr "Mostrar lixeira"

#: Settings.ui.h:51
msgid "Show volumes and devices"
msgstr "Mostrar volumes e dispositivos"

#: Settings.ui.h:52
msgid "Only if mounted"
msgstr "Somente se montados"

#: Settings.ui.h:53
msgid "Include network volumes"
msgstr "Incluir volumes de rede"

#: Settings.ui.h:54
msgid "Isolate volumes, devices and trash windows from file manager"
msgstr "Isolar as janelas de volumes, dispositivos e lixeira das do gerenciador de arquivos"

#: Settings.ui.h:55
msgid "Launchers"
msgstr "Lançadores"

#: Settings.ui.h:56
msgid ""
"Enable Super+(0-9) as shortcuts to activate apps. It can also be used "
"together with Shift and Ctrl."
msgstr ""
"Habilita tecla Super+(0-9) como atalhos para ativar aplicativos. Também pode "
"ser usado junto com Shift e Ctrl."

#: Settings.ui.h:57
msgid "Use keyboard shortcuts to activate apps"
msgstr "Usar atalhos de teclado para ativar aplicativos"

#: Settings.ui.h:58
msgid "Behaviour when clicking on the icon of a running application."
msgstr "Comportamento ao clicar sobre o ícone de um aplicativo em execução."

#: Settings.ui.h:59
msgid "Click action"
msgstr "Ação do clique"

#: Settings.ui.h:60
msgid "Minimize"
msgstr "Minimizar"

#: Settings.ui.h:61
msgid "Behaviour when scrolling on the icon of an application."
msgstr "Comportamento ao rolar sobre o ícone de um aplicativo."

#: Settings.ui.h:62
msgid "Scroll action"
msgstr "Ação da rolagem"

#: Settings.ui.h:63
msgid "Do nothing"
msgstr "Não fazer nada"

#: Settings.ui.h:64
msgid "Switch workspace"
msgstr "Alternar espaço de trabalho"

#: Settings.ui.h:65
msgid "Behavior"
msgstr "Comportamento"

#: Settings.ui.h:66
msgid ""
"Few customizations meant to integrate the dock with the default GNOME theme. "
"Alternatively, specific options can be enabled below."
msgstr ""
"Algumas personalizações destinadas a integrar o dock ao tema padrão do "
"GNOME. Como alternativa, opções específicas podem ser ativadas abaixo."

#: Settings.ui.h:67
msgid "Wiggle urgent applications"
msgstr "Fazer aplicativos urgentes balançarem"

#: Settings.ui.h:68
msgid "Hide application tooltip"
msgstr "Ocultar dica do aplicativo"

#: Settings.ui.h:69
msgid "Show icons emblems"
msgstr "Mostrar emblemas nos ícones"

#: Settings.ui.h:70
msgid "When enabled application icons will show notification counters and progress-bars (if Unity API is used)."
msgstr "Quando ativado, os ícones dos aplicativos mostrarão contadores de notificações e barras de progresso (se a API do Unity estiver em uso)."

#: Settings.ui.h:71
msgid "Show the number of unread notifications"
msgstr "Mostrar o número de notificações não lidas"

#: Settings.ui.h:72
msgid "Application-provided counter overrides the notifications counter"
msgstr "O contador fornecido pelo aplicativo substitui o contador de notificações"

#: Settings.ui.h:73
msgid "Use built-in theme"
msgstr "Usar tema integrado"

#: Settings.ui.h:68
msgid "Save space reducing padding and border radius."
msgstr "Economizar espaço reduzindo o espaçamento interno e o raio das bordas."

#: Settings.ui.h:69
msgid "Shrink the dash"
msgstr "Compactar o dock"

#: Settings.ui.h:70
msgid "Customize windows counter indicators"
msgstr "Personalizar os indicadores de contagem de janelas"

#: Settings.ui.h:71
msgid "Default"
msgstr "Padrão"

#: Settings.ui.h:72
msgid "Dots"
msgstr "Pontos"

#: Settings.ui.h:73
msgid "Squares"
msgstr "Quadrados"

#: Settings.ui.h:74
msgid "Dashes"
msgstr "Linhas"

#: Settings.ui.h:75
msgid "Segmented"
msgstr "Segmentado"

#: Settings.ui.h:76
msgid "Solid"
msgstr "Sólido"

#: Settings.ui.h:77
msgid "Ciliora"
msgstr "Ciliora"

#: Settings.ui.h:78
msgid "Metro"
msgstr "Metro"

#: Settings.ui.h:79
msgid "Binary"
msgstr "Binário"

#: Settings.ui.h:80
msgid "Dot"
msgstr "Ponto"

#: Settings.ui.h:81
msgid "Set the background color for the dash."
msgstr "Definir a cor de fundo do dock."

#: Settings.ui.h:80
msgid "Customize the dash color"
msgstr "Personalizar a cor do dock"

#: Settings.ui.h:81
msgid "Tune the dash background opacity."
msgstr "Ajustar a opacidade do fundo do dock."

#: Settings.ui.h:83
msgid "Fixed"
msgstr "Fixo"

#: Settings.ui.h:84
msgid "Dynamic"
msgstr "Dinâmico"

#: Settings.ui.h:85
msgid "Opacity"
msgstr "Opacidade"

#: Settings.ui.h:86
msgid "Force straight corner"
msgstr "Forçar canto reto"

#: Settings.ui.h:87
msgid "Show overview on startup"
msgstr "Mostrar visão geral ao inicializar"

#: Settings.ui.h:88
msgid "Appearance"
msgstr "Aparência"

#: Settings.ui.h:89
msgid "version: "
msgstr "versão: "

#: Settings.ui.h:90
msgid "Moves the dash out of the overview transforming it in a dock"
msgstr "Move o dash para fora da visão geral, transformando-o em um dock"

#: Settings.ui.h:91
msgid "Created by"
msgstr "Criado por"

#: Settings.ui.h:92
msgid "Webpage"
msgstr "Página web"

