#: Settings.ui.h:95
msgid "About"
msgstr "Sobre"

#: Settings.ui.h:96
msgid "Customize minimum and maximum opacity values"
msgstr "Personalizar os valores mínimo e máximo da opacidade"

#: Settings.ui.h:97
msgid "Minimum opacity"
msgstr "Opacidade mínima"

#: Settings.ui.h:98
msgid "Maximum opacity"
msgstr "Opacidade máxima"

#: Settings.ui.h:99
msgid "Number overlay"
msgstr "Sobreposição de número"

#: Settings.ui.h:100
msgid ""
"Temporarily show the application numbers over the icons, corresponding to "
"the shortcut."
msgstr ""
"Mostrar temporariamente os números dos aplicativos sobre os ícones, "
"correspondentes ao atalho."

#: Settings.ui.h:101
msgid "Show the dock if it is hidden"
msgstr "Mostrar o dock se ele estiver oculto"

#: Settings.ui.h:102
msgid ""
"If using autohide, the dock will appear for a short time when triggering the "
"shortcut."
msgstr ""
"Se a ocultação automática estiver ativada, o dock aparecerá por um curto "
"período ao acionar o atalho."

#: Settings.ui.h:103
msgid "Shortcut for the options above"
msgstr "Atalho para as opções acima"

#: Settings.ui.h:104
msgid "Syntax: <Shift>, <Ctrl>, <Alt>, <Super>"
msgstr "Sintaxe: <Shift>, <Ctrl>, <Alt>, <Super>"

#: Settings.ui.h:105
msgid "Hide timeout (s)"
msgstr "Tempo para ocultar (s)"

#: Settings.ui.h:106
msgid "Show the dock by mouse hover on the screen edge."
msgstr "Mostrar o dock ao passar o mouse na borda da tela."

#: Settings.ui.h:107
msgid "Autohide"
msgstr "Ocultação automática"

#: Settings.ui.h:108
msgid "Push to show: require pressure to show the dock"
msgstr "Pressionar para mostrar: exigir pressão para exibir o dock"

#: Settings.ui.h:109
msgid "Enable in fullscreen mode"
msgstr "Habilitar no modo de tela cheia"

#: Settings.ui.h:110
msgid "Show the dock when it doesn't obstruct application windows."
msgstr "Mostrar o dock quando ele não obstruir janelas de aplicativos."

#: Settings.ui.h:111
msgid "Dodge windows"
msgstr "Desviar das janelas"

#: Settings.ui.h:112
msgid "All windows"
msgstr "Todas as janelas"

#: Settings.ui.h:113
msgid "Only focused application's windows"
msgstr "Apenas as janelas do aplicativo em foco"

#: Settings.ui.h:114
msgid "Only maximized windows"
msgstr "Somente janelas maximizadas"

#: Settings.ui.h:115
msgid "Always on top"
msgstr "Sempre no topo"

#: Settings.ui.h:116
msgid "Animation duration (s)"
msgstr "Duração da animação (s)"

#: Settings.ui.h:117
msgid "Show timeout (s)"
msgstr "Tempo para mostrar (s)"

#: Settings.ui.h:118
msgid "Pressure threshold"
msgstr "Limite de pressão"

#: Settings.ui.h:122
msgid "Show dock for urgent notifications"
msgstr "Mostrar o dock para notificações urgentes"
